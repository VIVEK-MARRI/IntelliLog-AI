{
  "name": "intelliglog-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:load": "k6 run tests/load/dashboard.js",
    "smoke": "node scripts/smoke-checks.mjs",
    "demo:validate": "node scripts/demo-validate.mjs",
    "demo:validate:no-load": "SKIP_K6=1 node scripts/demo-validate.mjs",
    "demo:validate:no-e2e": "SKIP_PLAYWRIGHT=1 node scripts/demo-validate.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tanstack/react-query": "^4.36.1",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "three": "^0.184.0",
    "zod": "^4.4.3",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.52.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "ws": "^8.21.0"
  }
