# =============================================================================
# IntelliLog-AI Production Configuration
# =============================================================================
# WARNING: All secrets MUST be set. No default fallbacks exist.
# Generate a SECRET_KEY with: openssl rand -hex 32
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=logistics
POSTGRES_PASSWORD=changeme
POSTGRES_DB=intellilog

# --- Backend Application ---
DATABASE_URL=postgresql+asyncpg://logistics:changeme@postgres:5432/intellilog
REDIS_URL=redis://redis:6379/0

# REQUIRED: Generate with `openssl rand -hex 32`
SECRET_KEY=replace-with-64-char-hex-secret-key

# JWT expiration in hours (default: 24)
JWT_EXPIRATION=24

# Gemini LLM (optional — platform falls back gracefully when unset)
# GEMINI_API_KEY=your-gemini-api-key-here

# --- Rate Limiting (requests per minute) ---
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_POSITION_PER_MINUTE=300
RATE_LIMIT_COPILOT_PER_MINUTE=30
RATE_LIMIT_WS_PER_MINUTE=10

# --- Observability ---
PROMETHEUS_ENABLED=true
# Optional: Set a bearer token to protect the /metrics endpoint
# PROMETHEUS_AUTH_TOKEN=your-prometheus-scrape-token

# --- Deployment ---
ENVIRONMENT=production
API_HOST=0.0.0.0
API_PORT=8000
