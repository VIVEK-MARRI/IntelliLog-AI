# IntelliLog-AI Frontend Production Configuration

# API Base URL - Update with actual production domain
VITE_API_URL=https://api.intellilog.ai/api/v1

# Application Environment
VITE_ENV=production

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true

# Deployment Region
VITE_REGION=us-east-1
