# ============================================================================
# LLM Operational Insights Configuration Template
# Copy to .env and fill in your values
# ============================================================================

# LLM Provider Selection
# Options: "gemini" (default, lower cost) or "openai"
LLM_PROVIDER=gemini

# Google Gemini API Configuration
# Get API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY_LLM=your-google-gemini-api-key-here

# OpenAI API Configuration (optional, for fallback)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# Insights Service Configuration
# ============================================================================

# Cache TTL (Time To Live) for insight responses
# Higher values reduce API costs but increase stale data risk
# Recommended: 300 (5 min) to 600 (10 min)
INSIGHT_CACHE_TTL_SECONDS=300

# Max tokens per insight type (higher = more detailed but slower/costlier)
INSIGHT_MAX_TOKENS_DELAY=600              # Delay explanation
INSIGHT_MAX_TOKENS_FLEET=800              # Fleet summary
INSIGHT_MAX_TOKENS_ANOMALY=600            # Anomaly explanation
INSIGHT_MAX_TOKENS_ANALYTICS=1000         # Analytics insights

# ============================================================================
# Rate Limiting (requests per minute per tenant)
# ============================================================================

# Prevents API abuse and cost runaway
INSIGHT_RATE_LIMIT_DELAY_EXPLANATION=10   # Most common endpoint
INSIGHT_RATE_LIMIT_FLEET_SUMMARY=5        # Less frequent
INSIGHT_RATE_LIMIT_ANOMALIES=10
INSIGHT_RATE_LIMIT_ANALYTICS=2            # Heavy computation

# ============================================================================
# Cost Control & Monitoring
# ============================================================================

# Monthly token budget per tenant
# At ~$0.075 per 1M tokens (Gemini), this is ~$7.50/month per tenant
INSIGHT_MONTHLY_BUDGET_TOKENS=100000

# Enable cost tracking and monitoring
INSIGHT_ENABLE_COST_TRACKING=true

# ============================================================================
# Redis Cache Configuration (for insight response caching)
# ============================================================================

# Redis URL for insight caching
# Must be the same Redis instance used by the main application
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Example Setup Instructions
# ============================================================================
#
# 1. Get Gemini API Key:
#    - Visit: https://makersuite.google.com/app/apikey
#    - Click "Create API key"
#    - Copy the key and paste into GOOGLE_API_KEY_LLM
#
# 2. (Optional) Get OpenAI API Key:
#    - Visit: https://platform.openai.com/api-keys
#    - Click "Create new secret key"
#    - Copy and paste into OPENAI_API_KEY
#
# 3. Copy this template to .env:
#    cp .env.insights.template .env
#
# 4. Update .env with your API keys
#
# 5. Start server:
#    python -m src.backend.app.main
#
# ============================================================================
